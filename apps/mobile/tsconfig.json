{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "strict": true,
    "paths": {
      "@executive/types": ["../../packages/types/src"],
      "@/*": ["./src/*"]
