# Executive Concierge SP — API Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://executive:executive_dev_password@localhost:5432/executive_concierge

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev_password@localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Calendar ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/calendar/google/callback

# ─── Microsoft Calendar ───────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/calendar/microsoft/callback

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY
