// Executive Concierge SP — Prisma Schema
// Database: PostgreSQL
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  EXECUTIVE
  CONCIERGE_AGENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
}

enum ConversationStatus {
  ACTIVE
  HUMAN_HANDOFF
  RESOLVED
  ARCHIVED
}

enum MessageRole {
  USER
  AI
  AGENT
}

enum RequestStatus {
  PENDING
  ACKNOWLEDGED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RecommendationCategory {
  RESTAURANT
  WELLNESS
  SHORT_EXPERIENCE
  BUSINESS_SUPPORT
  MICRO_EXPERIENCE
}

enum NotificationType {
  REQUEST_UPDATE
  MESSAGE
  RECOMMENDATION
  SYSTEM
  REMINDER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  MFA_ENABLED
  MFA_DISABLED
  PASSWORD_CHANGED
  TOKEN_REVOKED
  DATA_EXPORTED
  DATA_DELETED
  AI_CALL
  HANDOFF_CREATED
  REQUEST_STATUS_CHANGED
  CALENDAR_CONNECTED
  CALENDAR_DISCONNECTED
  CALENDAR_SYNC_STARTED
  CALENDAR_SYNC_COMPLETED
  CALENDAR_SYNC_FAILED
  CALENDAR_TOKEN_REFRESHED
  CALENDAR_TOKEN_REFRESH_FAILED
  RECOMMENDATION_REQUESTED
  PREFERENCE_PROFILE_UPDATED
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  firstName   String
  lastName    String
  role        UserRole   @default(EXECUTIVE)
  status      UserStatus @default(ACTIVE)
  nationality String?
  company     String?
  title       String?
  timezone    String     @default("America/Sao_Paulo")
  avatarUrl   String?

  // Preferences stored as JSONB
  preferences Json @default("{}")

  // Auth
  passwordHash    String
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String? // encrypted
  mfaBackupCodes  String[] // encrypted

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  calendarConnections      CalendarConnection[]
  conversations            Conversation[]
  requests                 ConciergeRequest[]
  notifications            Notification[]
  invitations              Invitation[]           @relation("InvitedBy")
  refreshTokens            RefreshToken[]
  userInteractions         UserInteraction[]
  auditLogs                AuditLog[]             @relation("AuditSubject")
  agentRequests            ConciergeRequest[]     @relation("AssignedAgent")
  agentConversations       Conversation[]         @relation("AssignedAgent")
  agentMessages            Message[]              @relation("AgentMessages")
  pushTokens               PushToken[]
  preferenceProfile        PreferenceProfile?
  recommendationSessions   RecommendationSession[]
  recommendationFeedbacks  RecommendationFeedback[]

  @@index([email])
  @@index([role, status])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique // hashed
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Invitation {
  id          String    @id @default(uuid())
  email       String    @unique
  role        UserRole  @default(EXECUTIVE)
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime  @default(now())

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([token])
  @@map("invitations")
}

// ─── Calendar ─────────────────────────────────────────────────────────────────

model CalendarConnection {
  id              String           @id @default(uuid())
  userId          String
  provider        CalendarProvider
  accessToken     String           // encrypted (AES-256-GCM)
  refreshToken    String           // encrypted (AES-256-GCM)
  expiresAt       DateTime
  email           String?          // provider account email
  calendarId      String?          // primary calendar ID
  tenantId        String?          // Microsoft Azure tenant ID
  scopes          String[]         // granted OAuth scopes
  syncCursor      String?          // incremental sync cursor (nextSyncToken / deltaToken)
  syncedAt        DateTime?
  isActive        Boolean          @default(true)
  disconnectedAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       CalendarEvent[]
  syncAttempts CalendarSyncAttempt[]

  @@unique([userId, provider])
  @@map("calendar_connections")
}

model CalendarEvent {
  id           String   @id @default(uuid())
  connectionId String
  externalId   String
  title        String
  description  String?
  startAt      DateTime
  endAt        DateTime
  location     String?
  isAllDay     Boolean  @default(false)
  isCancelled  Boolean  @default(false)
  meetingUrl   String?  // video conference link (Meet, Teams, Zoom)
  organizer    String?  // organizer email
  attendees    Json?    // array of {email, name, status}
  raw          Json?    // raw provider payload (for debugging, never exposed to clients)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalId])
  @@index([connectionId, startAt])
  @@map("calendar_events")
}

// Tracks OAuth state tokens during the authorization flow (PKCE)
model OAuthState {
  id             String   @id @default(uuid())
  userId         String
  provider       CalendarProvider
  state          String   @unique // random state token
  codeVerifier   String   // PKCE verifier (stored server-side)
  redirectUri    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([state])
  @@index([userId])
  @@map("oauth_states")
}

// Audit trail for calendar sync operations
model CalendarSyncAttempt {
  id             String       @id @default(uuid())
  connectionId   String
  status         SyncStatus
  eventsAdded    Int          @default(0)
  eventsUpdated  Int          @default(0)
  eventsRemoved  Int          @default(0)
  errorMessage   String?
  durationMs     Int?
  triggeredBy    String       @default("scheduler") // "scheduler" | "user" | "connection"
  createdAt      DateTime     @default(now())

  connection CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@map("calendar_sync_attempts")
}

// ─── Concierge Chat ───────────────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(uuid())
  userId          String
  status          ConversationStatus @default(ACTIVE)
  assignedAgentId String?
  title           String?
  context         Json? // cached context used for AI
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id])
  assignedAgent User?              @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  messages      Message[]
  requests      ConciergeRequest[]

  @@index([userId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  agentId        String?
  tokensUsed     Int?
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent        User?        @relation("AgentMessages", fields: [agentId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── AI Audit ─────────────────────────────────────────────────────────────────

model AiCallLog {
  id           String   @id @default(uuid())
  userId       String?
  provider     String
  model        String
  promptTokens Int
  outputTokens Int
  durationMs   Int
  purpose      String // e.g., "concierge_chat", "recommendation_score"
  success      Boolean
  errorMessage String?
  requestHash  String? // SHA-256 of prompt for dedup
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([purpose, createdAt])
  @@map("ai_call_logs")
}

// ─── Recommendations ──────────────────────────────────────────────────────────

model Recommendation {
  id              String                 @id @default(uuid())
  title           String
  description     String
  category        RecommendationCategory
  venue           String?
  address         String?
  neighborhood    String?
  city            String                 @default("São Paulo")
  latitude        Float?
  longitude       Float?
  durationMinutes Int?
  minDurationMinutes  Int    @default(20)
  sourceType          String @default("SEED")
  premiumScore        Int    @default(3)
  suitableWindows     String[]
  priceLevel      Int                    @default(2) // 1-4
  tags            String[]
  imageUrl        String?
  websiteUrl      String?
  phoneNumber     String?
  openingHours    Json?
  isActive        Boolean                @default(true)
  curatedAt       DateTime               @default(now())
  curatedById     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  interactions UserInteraction[]

  @@index([category, isActive])
  @@index([neighborhood])
  @@map("recommendations")
}

model UserInteraction {
  id               String   @id @default(uuid())
  userId           String
  recommendationId String
  action           String // SAVED, DISMISSED, ACTED, VIEWED
  createdAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id])
  recommendation Recommendation @relation(fields: [recommendationId], references: [id])

  @@unique([userId, recommendationId, action])
  @@index([userId])
  @@map("user_interactions")
}

// ─── Requests ─────────────────────────────────────────────────────────────────

model ConciergeRequest {
  id                    String          @id @default(uuid())
  userId                String
  title                 String
  description           String
  status                RequestStatus   @default(PENDING)
  priority              RequestPriority @default(NORMAL)
  category              String?
  assignedAgentId       String?
  notes                 String?
  dueAt                 DateTime?
  completedAt           DateTime?
  conversationId        String?
  sourceRecommendationId String?        // tracks originating catalog item
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user          User                  @relation(fields: [userId], references: [id])
  assignedAgent User?                 @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  statusUpdates RequestStatusUpdate[]
  conversation  Conversation?         @relation(fields: [conversationId], references: [id])

  @@index([userId, status])
  @@index([assignedAgentId, status])
  @@map("concierge_requests")
}

model RequestStatusUpdate {
  id        String        @id @default(uuid())
  requestId String
  status    RequestStatus
  notes     String?
  agentId   String?
  createdAt DateTime      @default(now())

  request ConciergeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("request_status_updates")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String // ios, android
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

// ─── Audit Trail ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid())
  actorId     String? // Who did it (null = system)
  subjectId   String? // Who/what was affected
  subjectType String? // "User", "Request", etc.
  action      AuditAction
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  subject User? @relation("AuditSubject", fields: [subjectId], references: [id])

  @@index([actorId, createdAt])
  @@index([subjectId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── Recommendation Personalization ──────────────────────────────────────────

model PreferenceProfile {
  id                     String                   @id @default(uuid())
  userId                 String                   @unique
  foodPreferences        String[]
  dietaryConstraints     String[]
  atmospherePreferences  String[]
  preferredCategories    RecommendationCategory[]
  dislikedCategories     RecommendationCategory[]
  preferredDurationMin   Int                      @default(30)
  preferredDurationMax   Int                      @default(90)
  mobilityTolerance      String                   @default("moderate")
  preferredNeighborhoods String[]
  pacing                 String                   @default("efficient")
  wellnessInterest       Boolean                  @default(false)
  businessTravelStyle    String                   @default("premium")
  additionalNotes        String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preference_profiles")
}

model RecommendationSession {
  id              String   @id @default(uuid())
  userId          String
  windowStart     DateTime
  windowEnd       DateTime
  contextSnapshot Json
  resultsSnapshot Json
  requestedAt     DateTime @default(now())

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbacks RecommendationFeedback[]

  @@index([userId, requestedAt])
  @@map("recommendation_sessions")
}

model RecommendationFeedback {
  id            String   @id @default(uuid())
  sessionId     String
  userId        String
  catalogItemId String
  action        String
  reason        String?
  createdAt     DateTime @default(now())

  session RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, catalogItemId])
  @@map("recommendation_feedbacks")
}
